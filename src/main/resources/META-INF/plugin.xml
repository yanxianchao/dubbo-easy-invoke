<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.github.yanxianchao.dubboeasyinvoke</id>
    <name>Dubbo Easy Invoke</name>
    <vendor email="xianchao.yan@qq.com" url="https://github.com/yanxianchao">xianchao</vendor>

    <idea-version since-build="252.25557"/>

    <description><![CDATA[
    <h3>Dubbo Easy Invoke</h3>
    <p>在 IntelliJ IDEA 内完成 Dubbo 联调闭环：发现接口、快速调用、解析信息、收藏复用。</p>
    <ul>
        <li>接口发现：应用/接口联动 + 关键字实时搜索</li>
        <li>快速调用：参数/结果自动 JSON 格式化，支持一键粘贴与复制</li>
        <li>接口解析：服务地址、消费应用、超时时间、二方包版本、DUBBO 版本清晰展示</li>
        <li>收藏夹：按应用筛选、关键字搜索、重命名、删除与一键回填</li>
        <li>稳定体验：缓存优先加载、后台刷新、注册中心异常回退、分色 Console 日志</li>
    </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="com.github.yanxianchao.dubboeasyinvoke.settings"
                displayName="Dubbo Easy Invoke"
                parentId="tools"
                instance="com.github.yanxianchao.dubboeasyinvoke.settings.DubboInvokeSettingsConfigurable"/>

        <toolWindow
                id="Dubbo Invoke"
                anchor="right"
                canCloseContents="false"
                factoryClass="com.github.yanxianchao.dubboeasyinvoke.toolwindow.DubboInvokeToolWindowFactory"/>
    </extensions>
</idea-plugin>
